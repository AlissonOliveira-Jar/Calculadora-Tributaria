datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  calculos  Calculo[]
}

model Calculo {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipoProfissao  String
  faturamento    Float
  impostoPF      Float
  impostoPJ      Float
  melhorOpcao    String   // "PF" ou "PJ"
  economiaMensal Float
  createdAt      DateTime @default(now())
}